# Copy this file to .env and fill in the required secrets.
# Never commit a real .env file.

# Required: Replicate API token for Whisper transcription.
REPLICATE_API_TOKEN=

# Required: DeepSeek API key for subtitle translation.
SUBTRANS_DEEPSEEK_API_KEY=
# Optional compatibility fallback. Leave empty if SUBTRANS_DEEPSEEK_API_KEY is set.
DEEPSEEK_API_KEY=

# Paths and storage.
SUBTRANS_DATA_DIR=./data
SUBTRANS_DB=./app.db

# Background pipeline.
SUBTRANS_WORKERS=2

# Download settings.
SUBTRANS_DL_FORMAT=bv*+ba/b
SUBTRANS_DL_CONTAINER=mp4
SUBTRANS_DL_RETRIES=3
# Optional cookies file for sites that require login or age verification.
SUBTRANS_COOKIES=

# FFmpeg tools.
SUBTRANS_FFMPEG=ffmpeg
SUBTRANS_FFPROBE=ffprobe
SUBTRANS_AUDIO_SR=16000
SUBTRANS_AUDIO_CH=1

# Replicate Whisper settings.
SUBTRANS_WHISPER_MODEL=stayallive/whisper-subtitles:b97ba81004e7132181864c885a76cae0e56bc61caa4190a395f6d8ba45b7a969
SUBTRANS_REPLICATE_TIMEOUT=1800
SUBTRANS_REPLICATE_RETRIES=3

# DeepSeek OpenAI-compatible API settings.
SUBTRANS_DEEPSEEK_BASE_URL=https://api.deepseek.com
SUBTRANS_DEEPSEEK_MODEL=deepseek-chat
SUBTRANS_TRANSLATE_BATCH=8
SUBTRANS_TRANSLATE_TIMEOUT=60
